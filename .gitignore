# Root .gitignore for AI Resume Builder

# ===========================
# Node / npm
# ===========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js

# ===========================
# Environment Variables (NEVER commit these!)
# ===========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ===========================
# Build outputs
# ===========================
build/
dist/

# ===========================
# OS files
# ===========================
.DS_Store
Thumbs.db
desktop.ini

# ===========================
# Editor / IDE
# ===========================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ===========================
# Logs
# ===========================
logs/
*.log

# ===========================
# Coverage reports
# ===========================
coverage/
.nyc_output/
